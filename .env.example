# ── ORA — Prayer Warrior · environment variables ──────────────────────────────
# All are OPTIONAL. The app runs without them, degrading gracefully:
#   - no readings keys  -> public-domain Douay–Rheims (and a representative
#     fallback when USCCB is unreachable)
#   - no TTS key         -> the browser's built-in voice

# Crossway ESV API (https://api.esv.org/). When set, the protocanon renders in
# the ESV; the deuterocanon stays Douay–Rheims. Non-commercial free tier — a
# public/commercial app needs a Crossway licence.
ESV_API_KEY=

# Google Cloud Text-to-Speech (https://console.cloud.google.com/, enable the
# "Cloud Text-to-Speech API" and create an API key restricted to it). When set,
# narration uses a natural human voice instead of the browser voice.
GOOGLE_TTS_API_KEY=

# Optional default voice (users can override it in Settings). e.g. en-US-Neural2-D
GOOGLE_TTS_VOICE=

# Anthropic Claude (https://console.anthropic.com/). Powers the "Today in the
# Church" briefing and the Saint of the Day profiles — Claude searches credible
# Catholic sources and returns an accurate, grounded profile (history,
# canonization, patronage, how to keep the feast) with citations. Without it,
# the saint page shows the curated bio only.
ANTHROPIC_API_KEY=

# Optional: protect the saint-profile backfill endpoint
# (/api/saint-profile/backfill?token=...). If unset, the endpoint is open.
BACKFILL_TOKEN=
